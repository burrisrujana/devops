        <!-- BRONZE -->
        <mxCell id="bronze" value="&lt;b style=&quot;font-size:14px&quot;&gt;BRONZE&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Raw data — exact copy&lt;br&gt;from source systems&lt;br&gt;&lt;br&gt;No transformations&lt;br&gt;Append-only writes&lt;br&gt;Full history kept&lt;br&gt;&lt;br&gt;&lt;b&gt;S3 Bucket:&lt;/b&gt;&lt;br&gt;project-bronze-{env}&lt;br&gt;&lt;br&gt;&lt;b&gt;Format:&lt;/b&gt; Delta Tables&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CD7F32;strokeColor=#8B5A2B;fontColor=#FFFFFF;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
